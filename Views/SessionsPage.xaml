<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:MyConference.ViewModels"
             xmlns:models="clr-namespace:MyConference.Models"
             x:Class="MyConference.Views.SessionsPage"
             x:DataType="viewModels:SessionsViewModel"
             Title="Sessions">

    <Grid>
        <!-- Main content -->
        <RefreshView IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding SessionGroups}"
                            IsGrouped="True"
                            SelectionMode="None">

                <CollectionView.Header>
                    <VerticalStackLayout Spacing="0">
                        <!-- Search bar -->
                        <Border StrokeShape="RoundRectangle 10"
                                StrokeThickness="0"
                                BackgroundColor="{StaticResource SurfaceVariant}"
                                Margin="16,8,16,8"
                                Padding="12,0"
                                HeightRequest="44">
                            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                <Label Text="🔍" FontSize="14" VerticalOptions="Center" Opacity="0.5" />
                                <Entry Text="{Binding SearchText}"
                                       Placeholder="Search sessions or speakers..."
                                       PlaceholderColor="{StaticResource TextSecondary}"
                                       TextColor="{StaticResource TextPrimary}"
                                       BackgroundColor="Transparent"
                                       FontSize="15"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Fill" />
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Offline banner -->
                        <Border IsVisible="{Binding IsOffline}"
                                BackgroundColor="{StaticResource Accent}"
                                Padding="8,4" Margin="0">
                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                                <Label Text="📡" FontSize="14" VerticalOptions="Center" />
                                <Label Text="Offline mode — showing cached data" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Day selector chips -->
                        <ScrollView Orientation="Horizontal"
                                    HorizontalScrollBarVisibility="Never"
                                    IsVisible="{Binding IsMultiDay}">
                            <HorizontalStackLayout Spacing="8"
                                                   Padding="16,4,16,8"
                                                   BindableLayout.ItemsSource="{Binding Days}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border StrokeShape="RoundRectangle 16"
                                                Padding="14,6"
                                                StrokeThickness="0"
                                                BackgroundColor="{StaticResource SurfaceVariant}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:SessionsViewModel}}, Path=SelectDayCommand}"
                                                    CommandParameter="{Binding}" />
                                            </Border.GestureRecognizers>
                                            <Label Text="{Binding}"
                                                   FontSize="13"
                                                   HorizontalTextAlignment="Center"
                                                   TextColor="{StaticResource TextSecondary}" />
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </ScrollView>
                    </VerticalStackLayout>
                </CollectionView.Header>

                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate x:DataType="models:TimeSlotGroup">
                        <VerticalStackLayout Padding="20,20,20,8">
                            <HorizontalStackLayout Spacing="8">
                                <Border StrokeShape="RoundRectangle 6" StrokeThickness="0"
                                        BackgroundColor="{StaticResource PrimaryLight}" Padding="8,4">
                                    <Label Text="{Binding TimeSlot}"
                                           FontSize="13" FontAttributes="Bold"
                                           TextColor="{StaticResource PrimaryDark}" />
                                </Border>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Session">
                        <Border Style="{StaticResource CardBorder}" Margin="16,5" Padding="0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:SessionsViewModel}}, Path=NavigateToSessionCommand}"
                                    CommandParameter="{Binding}" />
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="*,Auto" Padding="16,14">
                                <!-- Main content -->
                                <VerticalStackLayout Spacing="10">
                                    <!-- Title -->
                                    <Label Text="{Binding Title}"
                                           FontSize="16" FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"
                                           LineBreakMode="WordWrap" />

                                    <!-- Room chip -->
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="📍" FontSize="11" VerticalOptions="Center" />
                                        <Label Text="{Binding RoomName}"
                                               FontSize="12"
                                               TextColor="{StaticResource TextSecondary}"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>

                                    <!-- Speakers row -->
                                    <HorizontalStackLayout Spacing="8" Margin="0,2,0,0">
                                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding SpeakerProfiles}">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="models:Speaker">
                                                    <Border StrokeShape="RoundRectangle 16"
                                                            StrokeThickness="2"
                                                            Stroke="{StaticResource Surface}"
                                                            WidthRequest="32"
                                                            HeightRequest="32"
                                                            Margin="-6,0,0,0">
                                                        <Image Source="{Binding ProfilePicture}"
                                                               Aspect="AspectFill" />
                                                    </Border>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </HorizontalStackLayout>

                                        <Label VerticalOptions="Center"
                                               FontSize="13"
                                               TextColor="{StaticResource TextSecondary}"
                                               LineBreakMode="TailTruncation"
                                               Text="{Binding SpeakerNames}" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <!-- Favorite heart -->
                                <Button Grid.Column="1"
                                        Text="♥" FontSize="18"
                                        BackgroundColor="Transparent"
                                        BorderWidth="0" Padding="4"
                                        MinimumWidthRequest="32"
                                        MinimumHeightRequest="32"
                                        VerticalOptions="Start"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:SessionsViewModel}}, Path=ToggleFavoriteCommand}"
                                        CommandParameter="{Binding}">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsFavorite}" Value="True">
                                            <Setter Property="TextColor" Value="{StaticResource FavoriteActive}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsFavorite}" Value="False">
                                            <Setter Property="TextColor" Value="{StaticResource FavoriteInactive}" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Padding="32">
                        <Label Text="No sessions found"
                               Style="{StaticResource SubtitleLabel}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

            </CollectionView>
        </RefreshView>

        <!-- Loading indicator -->
        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />
    </Grid>

</ContentPage>
