<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:MyConference.ViewModels"
             xmlns:models="clr-namespace:MyConference.Models"
             x:Class="MyConference.Views.SessionDetailPage"
             x:DataType="viewModels:SessionDetailViewModel"
             Title="Session"
             Shell.NavBarIsVisible="False">

    <Grid>
        <ScrollView IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
            <VerticalStackLayout Spacing="0">

                <!-- Hero header with gradient background -->
                <Grid HeightRequest="220">
                    <BoxView BackgroundColor="{StaticResource Primary}" />
                    <!-- Decorative circles -->
                    <Border StrokeThickness="0"
                            BackgroundColor="{StaticResource PrimaryDark}"
                            Opacity="0.3"
                            StrokeShape="RoundRectangle 80"
                            WidthRequest="160" HeightRequest="160"
                            HorizontalOptions="End" VerticalOptions="Start"
                            TranslationX="40" TranslationY="-40" />
                    <Border StrokeThickness="0"
                            BackgroundColor="{StaticResource PrimaryDark}"
                            Opacity="0.2"
                            StrokeShape="RoundRectangle 60"
                            WidthRequest="120" HeightRequest="120"
                            HorizontalOptions="Start" VerticalOptions="End"
                            TranslationX="-30" TranslationY="20" />

                    <!-- Back button + favorite -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="12,52,12,0" VerticalOptions="Start">
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 20"
                                StrokeThickness="0" BackgroundColor="#33FFFFFF"
                                WidthRequest="40" HeightRequest="40">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="‹" FontSize="28" TextColor="White"
                                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Border>
                        <Border Grid.Column="2" StrokeShape="RoundRectangle 20"
                                StrokeThickness="0" BackgroundColor="#33FFFFFF"
                                WidthRequest="40" HeightRequest="40">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleFavoriteCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="♥" FontSize="20"
                                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsFavorite}" Value="True">
                                        <Setter Property="TextColor" Value="{StaticResource FavoriteActive}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsFavorite}" Value="False">
                                        <Setter Property="TextColor" Value="White" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>
                    </Grid>

                    <!-- Title on hero -->
                    <VerticalStackLayout VerticalOptions="End" Padding="20,0,20,24" Spacing="8">
                        <Label Text="{Binding Session.Title, FallbackValue=''}"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="White" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Info chips row -->
                <HorizontalStackLayout Spacing="10" Padding="20,16,20,0">
                    <!-- Time chip -->
                    <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                            BackgroundColor="{StaticResource PrimaryLight}" Padding="10,6">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="🕐" FontSize="13" VerticalOptions="Center" />
                            <Label Text="{Binding Session.TimeSlot, FallbackValue=''}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                    <!-- Room chip -->
                    <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                            BackgroundColor="{StaticResource SurfaceVariant}" Padding="10,6">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="📍" FontSize="13" VerticalOptions="Center" />
                            <Label Text="{Binding Session.RoomName, FallbackValue=''}"
                                   FontSize="13" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                </HorizontalStackLayout>

                <!-- Description section -->
                <VerticalStackLayout Padding="20,20,20,0" Spacing="8">
                    <Label Text="About this session"
                           FontSize="16" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label Text="{Binding Session.Description, FallbackValue=''}"
                           FontSize="15" LineHeight="1.6"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>

                <!-- Speakers section -->
                <VerticalStackLayout Padding="20,24,20,24" Spacing="12">
                    <Label Text="Speakers"
                           FontSize="16" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />

                    <VerticalStackLayout Spacing="12"
                                         BindableLayout.ItemsSource="{Binding Session.SpeakerProfiles, FallbackValue={x:Null}}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:Speaker">
                                <Border Style="{StaticResource CardBorder}" Padding="16">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:SessionDetailViewModel}}, Path=NavigateToSpeakerCommand}"
                                            CommandParameter="{Binding}" />
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="64,*,Auto" ColumnSpacing="14">
                                        <!-- Large avatar -->
                                        <Border StrokeShape="RoundRectangle 32"
                                                StrokeThickness="3"
                                                Stroke="{StaticResource PrimaryLight}"
                                                WidthRequest="64" HeightRequest="64">
                                            <Image Source="{Binding ProfilePicture}"
                                                   Aspect="AspectFill" />
                                        </Border>

                                        <!-- Name + tagline -->
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                            <Label Text="{Binding FullName}"
                                                   FontSize="16" FontAttributes="Bold"
                                                   TextColor="{StaticResource TextPrimary}" />
                                            <Label Text="{Binding TagLine}"
                                                   FontSize="13"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2" />
                                        </VerticalStackLayout>

                                        <!-- Chevron -->
                                        <Label Grid.Column="2" Text="›" FontSize="24"
                                               TextColor="{StaticResource TextSecondary}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Loading indicator -->
        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />
    </Grid>

</ContentPage>
