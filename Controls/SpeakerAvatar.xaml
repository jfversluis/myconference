<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyConference.Controls.SpeakerAvatar"
             x:Name="AvatarView">
    <Border StrokeShape="RoundRectangle 20"
            StrokeThickness="2"
            Stroke="{StaticResource Surface}"
            WidthRequest="40"
            HeightRequest="40">
        <Image Source="{Binding Source={x:Reference AvatarView}, Path=ImageSource}"
               Aspect="AspectFill" />
    </Border>
</ContentView>
