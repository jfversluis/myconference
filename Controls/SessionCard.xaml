<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:MyConference.Models"
             x:Class="MyConference.Controls.SessionCard"
             x:DataType="models:Session">

    <Border Style="{StaticResource CardBorder}" Margin="16,4">
        <VerticalStackLayout Spacing="6" Padding="14,10">

            <!-- Top row: time, room, favorite -->
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <Label Grid.Column="0"
                       Style="{StaticResource TimeLabel}"
                       Text="{Binding TimeSlot}" />
                <Label Grid.Column="1"
                       Text="•"
                       Margin="6,0"
                       VerticalOptions="Center"
                       Opacity="0.5" />
                <Label Grid.Column="2"
                       Style="{StaticResource RoomLabel}"
                       Text="{Binding RoomName}" />
                <Label Grid.Column="3"
                       Text="♥"
                       FontSize="20"
                       VerticalOptions="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsFavorite}" Value="True">
                            <Setter Property="TextColor" Value="{StaticResource FavoriteActive}" />
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding IsFavorite}" Value="False">
                            <Setter Property="TextColor" Value="{StaticResource FavoriteInactive}" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Grid>

            <!-- Title -->
            <Label Style="{StaticResource CardTitleLabel}"
                   Text="{Binding Title}" />

            <!-- Speakers row -->
            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                <HorizontalStackLayout BindableLayout.ItemsSource="{Binding SpeakerProfiles}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:Speaker">
                            <Border StrokeShape="RoundRectangle 14"
                                    StrokeThickness="2"
                                    Stroke="{StaticResource Surface}"
                                    WidthRequest="28"
                                    HeightRequest="28"
                                    Margin="-6,0,0,0">
                                <Image Source="{Binding ProfilePicture}"
                                       Aspect="AspectFill" />
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>

                <Label VerticalOptions="Center"
                       FontSize="13"
                       Opacity="0.7"
                       LineBreakMode="TailTruncation"
                       Text="{Binding SpeakerNames}" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </Border>

</ContentView>
